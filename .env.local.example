# =============================================================================
# Finanzas Familia — Variables de entorno
# Copialo a .env.local y pegá tus credenciales reales.
# =============================================================================

# Neon Postgres
# Lo obtenés en https://console.neon.tech → Connection details (Pooled connection)
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require

# Neon Auth (Stack)
# Las da Neon cuando habilitás Auth en el dashboard del proyecto.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Opcional: URL pública (para links en emails de invitación)
NEXT_PUBLIC_APP_URL=http://localhost:3000
