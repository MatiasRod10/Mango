# =============================================================================
# Mango — Variables de entorno
# Copialo a .env.local y pegá tus credenciales reales. Gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Neon Postgres
# console.neon.tech → tu proyecto → Connection details → Pooled connection
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require

# -----------------------------------------------------------------------------
# Stack Auth — dashboard del proyecto Stack
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# -----------------------------------------------------------------------------
# Twelve Data — precios de acciones / CEDEARs (auto-actualizar inversiones)
# Sign up gratis en https://twelvedata.com/register
# Free tier: 800 calls/día · 8 calls/min — más que suficiente para Mango
# Si lo dejás vacío, el auto-pricing de acciones/CEDEARs no funciona
# (cripto + dólar siguen andando vía CoinGecko + dolarapi)
# -----------------------------------------------------------------------------
TWELVE_DATA_API_KEY=

# -----------------------------------------------------------------------------
# URL pública del app local
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3003
